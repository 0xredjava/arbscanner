# =============================================================================
# Sports Arbitrage Scanner — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.
# =============================================================================

# --- General ---
LOG_LEVEL=INFO
SCAN_INTERVAL_SECONDS=60
MAX_EVENT_HORIZON_DAYS=14
MIN_PROFIT_PCT=2.0
DEFAULT_BANKROLL=1000.0
ADMIN_TOKEN=change-me
CORS_ORIGINS=http://localhost:3000

# Fee / slippage assumptions (percent)
DEFAULT_PLATFORM_FEE_PCT=2.0
SLIPPAGE_PCT=1.0
LIQUIDITY_BUFFER_PCT=5.0

# Watched sports (comma-separated)
WATCHED_SPORTS=soccer,nba,tennis,nfl,nhl,mlb

# --- Platform toggles ---
ENABLE_POLYMARKET=true
ENABLE_STAKE=true
ENABLE_BCGAME=true
ENABLE_SHUFFLE=true
ENABLE_CLOUDBET=true
ENABLE_TGCASINO=true
ENABLE_THUNDERPICK=true

# --- Polymarket ---
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com

# --- The Odds API (optional aggregator) ---
THE_ODDS_API_KEY=
THE_ODDS_API_URL=https://api.the-odds-api.com/v4

# --- Cloudbet ---
CLOUDBET_API_URL=https://sports-api.cloudbet.com/pub/v2
CLOUDBET_API_KEY=

BCGAME_FEED_URL=https://api-k-c7818b61-623.sptpub.com
BCGAME_BRAND_ID=2103509236163162112
TGCASINO_FEED_URL=https://api-a-c7818b61-600.sptpub.com
TGCASINO_BRAND_ID=2352178356470026240
SHUFFLE_SPORTS_GRAPHQL_URL=https://shuffle.com/main-api/graphql/sports/graphql-sports
THUNDERPICK_API_URL=https://thunderpick.io/api

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Matcher ---
FUZZY_MATCH_THRESHOLD=75
MAX_EVENT_TIME_DIFF_MINUTES=120

# --- Output paths ---
JSON_LOG_PATH=data/arbs.json
